---
import "../styles/navbar.css";
---

<nav class="nav">
  <div>
    <img
      id="langBtn"
      class="icons"
      src="https://unpkg.com/pixelarticons@latest/svg/languages.svg"
    />
    <img
      id="soundBtn"
      class="icons"
      src="https://unpkg.com/pixelarticons@1.8.1/svg/volume-x.svg"
      style="cursor: pointer;"
    />
  </div>
  <div id="date" class="nav-center"></div>
  <img
    class="icons"
    src="https://unpkg.com/pixelarticons@latest/svg/power.svg"
  />
</nav>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const langBtn = document.getElementById("langBtn");
    const soundBtn = document.getElementById("soundBtn");
    const dateEl = document.getElementById("date");

    let audioStarted = false;
    let isMuted = true;

    let lang = localStorage.getItem("lang");
    if (!lang) {
      const browserLang = navigator.language || "en";
      lang = browserLang.startsWith("es") ? "es" : "en";
      localStorage.setItem("lang", lang);
    }
    updateFlag(lang);

    langBtn.addEventListener("click", () => {
      const current = localStorage.getItem("lang") || "en";
      const next = current === "es" ? "en" : "es";
      localStorage.setItem("lang", next);
      sessionStorage.setItem("isLangSwitch", "true");
      location.reload();
    });

    function updateFlag(lang) {
      langBtn.src =
        lang === "es"
          ? "https://hatscripts.github.io/circle-flags/flags/ar.svg"
          : "https://hatscripts.github.io/circle-flags/flags/us.svg";
    }

    window.addEventListener("syncKnightAudio", (e) => {
      const { isMuted: newMutedStatus, started } = e.detail;
      audioStarted = started;
      isMuted = newMutedStatus;

      soundBtn.src = isMuted
        ? "https://unpkg.com/pixelarticons@1.8.1/svg/volume-x.svg"
        : "https://unpkg.com/pixelarticons@1.8.1/svg/volume-2.svg";
    });

    soundBtn.addEventListener("click", () => {
      isMuted = !isMuted;
      const audio = window.knightAudio;

      if (audio) {
        audio.muted = isMuted;
      }

      soundBtn.src = isMuted
        ? "https://unpkg.com/pixelarticons@1.8.1/svg/volume-x.svg"
        : "https://unpkg.com/pixelarticons@1.8.1/svg/volume-2.svg";

      window.dispatchEvent(
        new CustomEvent("syncKnightAudio", {
          detail: { isMuted: isMuted, started: audioStarted },
        }),
      );
    });

    function updateDate() {
      const lang = localStorage.getItem("lang") || "en";
      const locale = lang === "es" ? "es-AR" : "en-US";

      dateEl.textContent = new Date().toLocaleString(locale, {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    updateDate();
    setInterval(updateDate, 1000);
  });
</script>
