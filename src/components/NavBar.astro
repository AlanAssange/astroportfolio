---
import "../styles/navbar.css";
---

<nav class="nav">
  <div>
    <img
      id="langBtn"
      class="icons"
      src="https://hatscripts.github.io/circle-flags/flags/us.svg"
    />
    <img
      id="soundBtn"
      class="icons"
      src="https://unpkg.com/pixelarticons@1.8.1/svg/volume-x.svg"
      style="cursor: pointer;"
    />
  </div>
  <div id="date" class="nav-center"></div>
  
  <img
    id="powerBtn"
    class="icons"
    src="https://unpkg.com/pixelarticons@latest/svg/power.svg"
    style="cursor: pointer;"
  />
</nav>

<div id="powerModal" class="modal-overlay" style="display: none;">
  <div class="modal-content fantasy-window">
    <div class="modal-header">
      <span id="t-system"></span>
    </div>
    <div class="modal-body">
      <p id="t-status"></p>
      <p id="t-areusure"></p>
    </div>
    <div class="modal-actions">
      <button id="btnYes" class="modal-btn fantasy-btn"></button>
      <button id="btnNo" class="modal-btn fantasy-btn"></button>
    </div>
  </div>
</div>

<script>
  import i18next from "../i18n/i18n";
  import { useStore } from "../utils/useStore";

  document.addEventListener("DOMContentLoaded", async () => {
    const langBtn = document.getElementById("langBtn") as HTMLImageElement;
    const soundBtn = document.getElementById("soundBtn") as HTMLImageElement;
    const powerBtn = document.getElementById("powerBtn") as HTMLImageElement;
    const powerModal = document.getElementById("powerModal") as HTMLDivElement;
    const btnYes = document.getElementById("btnYes") as HTMLButtonElement;
    const btnNo = document.getElementById("btnNo") as HTMLButtonElement;
    const dateEl = document.getElementById("date") as HTMLDivElement;

    const translateUI = () => {
      const els: Record<string, string> = {
        "t-system": "navbar.system",
        "t-status": "navbar.status",
        "t-areusure": "navbar.areusure",
        "btnYes": "navbar.yes",
        "btnNo": "navbar.no"
      };
      for (const [id, key] of Object.entries(els)) {
        document.getElementById(id)!.textContent = i18next.t(key);
      }
    };

    const updateFlag = (lang: string) => {
      langBtn.src = lang === "es" 
        ? "https://hatscripts.github.io/circle-flags/flags/ar.svg" 
        : "https://hatscripts.github.io/circle-flags/flags/us.svg";
    };

    const updateDate = () => {
      const currentLang = localStorage.getItem("lang") || "en";
      dateEl.textContent = new Date().toLocaleString(currentLang === "es" ? "es-AR" : "en-US", {
        day: "2-digit", month: "2-digit", year: "numeric",
        hour: "2-digit", minute: "2-digit",
      });
    };

    let lang = localStorage.getItem("lang");
    if (!lang) {
      lang = navigator.language.startsWith("es") ? "es" : "en";
      localStorage.setItem("lang", lang);
    }

    await i18next.changeLanguage(lang);
    translateUI();
    updateFlag(lang);
    updateDate();
    setInterval(updateDate, 1000);

    langBtn.addEventListener("click", async () => {
      const next = localStorage.getItem("lang") === "es" ? "en" : "es";
      localStorage.setItem("lang", next);
      await i18next.changeLanguage(next);
      translateUI();
      updateFlag(next);
      updateDate();
    });

    const updateSoundIcon = (isMuted: boolean) => {
      soundBtn.src = isMuted
        ? "https://unpkg.com/pixelarticons@1.8.1/svg/volume-x.svg"
        : "https://unpkg.com/pixelarticons@1.8.1/svg/volume-2.svg";
    };

    updateSoundIcon(useStore.getState().isMuted);

    useStore.subscribe((state) => {
      updateSoundIcon(state.isMuted);
    });

    soundBtn.addEventListener("click", () => {
      const state = useStore.getState();
      
      if (!state.isAudioStarted) {
        state.startAudio();
      } else {
        state.toggleAudio();
      }
    });

    powerBtn.addEventListener("click", () => powerModal.style.display = "flex");
    btnNo.addEventListener("click", () => powerModal.style.display = "none");
    btnYes.addEventListener("click", () => window.location.href = "/thankyou");
  });
</script>